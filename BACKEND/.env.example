# Use MongoDB Atlas or another cloud/replica-set MongoDB. Click recording, account
# deletion, and other flows use transactions (not supported on plain standalone local Mongo).

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/url_shortener
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars
FRONT_END_URL=http://127.0.0.1:5173
PORT=3001
NODE_ENV=development
# Leave empty for local dev (localhost/127.0.0.1 auto-allowed). Set in production.
ALLOWED_ORIGINS=
# Public URL for short links / QR (defaults to request host; set if API domain differs)
PUBLIC_BASE_URL=http://127.0.0.1:3001
# Express "trust proxy" hop count — REQUIRED in production (no default).
# Railway / Render / Fly (one reverse proxy in front): TRUST_PROXY=1
# Direct exposure with no proxy: TRUST_PROXY=0
# Multiple proxy hops: set to the number of trusted hops (e.g. TRUST_PROXY=2)
TRUST_PROXY=1
# Optional: lax | strict | none — defaults to lax; use none only for an intentional cross-site deployment
# COOKIE_SAME_SITE=none
# Maximum active links per registered user (integer from 1 to 100000)
MAX_LINKS_PER_USER=1000
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=Shortly <noreply@yourdomain.com>
# Operator inboxes for abuse reports and operational contact (optional in dev)
OPERATOR_EMAIL=support@yourdomain.com
ABUSE_INBOX_EMAIL=abuse@yourdomain.com
# Comma-separated operator emails allowed to access /api/admin/abuse (abuse queue UI)
ADMIN_EMAILS=abuse@yourdomain.com
# Optional webhook for operational alerts, including hidden email delivery failures
OPERATIONS_ALERT_WEBHOOK_URL=https://alerts.example.com/shortly
# Public frontend URL for email images (required when FRONT_END_URL is localhost)
EMAIL_ASSET_BASE_URL=https://shortly.nayanswarnkar.com
