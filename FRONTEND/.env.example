# Dev: leave empty — Vite proxies /api to the backend (no CORS).
# Production build: set to your API origin (also used to generate vercel.json rewrites).
VITE_APP_URL=
# Dev: frontend origin — Vite proxies short slugs to backend redirects.
# Prod (Vercel): backend origin for short-link rewrites. Defaults to VITE_APP_URL when unset.
# Set in Vercel project env; used by `npm run generate:vercel` during build.
SHORT_LINK_PROXY_ORIGIN=
# Prod: public short-link domain shown in copy/QR and canonical URLs (e.g. https://shortly.example.com).
# Must match the Vercel frontend host when using branded short URLs.
VITE_PUBLIC_SHORT_URL=http://127.0.0.1:5173
# Dev: backend origin for the Vite proxy (defaults to http://127.0.0.1:3001)
VITE_BACKEND_DEV_URL=http://127.0.0.1:3001
# Public operator contact addresses shown on legal/trust pages (override per deployment)
VITE_OPERATOR_NAME=Shortly
VITE_SUPPORT_EMAIL=support@shortly.nayanswarnkar.com
VITE_ABUSE_EMAIL=abuse@shortly.nayanswarnkar.com
VITE_SECURITY_EMAIL=security@shortly.nayanswarnkar.com
# Comma-separated admin emails that can open /admin/abuse (must match backend ADMIN_EMAILS)
VITE_ADMIN_EMAILS=abuse@shortly.nayanswarnkar.com
