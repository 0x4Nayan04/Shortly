# Use MongoDB Atlas or another cloud/replica-set MongoDB. Click analytics use
# transactions, which are not supported by a plain standalone local MongoDB.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/url_shortener
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars
FRONT_END_URL=http://127.0.0.1:5173
PORT=3001
NODE_ENV=development
# Leave empty for local dev (localhost/127.0.0.1 auto-allowed). Set in production.
ALLOWED_ORIGINS=
# Public URL for short links / QR (defaults to request host; set if API domain differs)
PUBLIC_BASE_URL=http://127.0.0.1:3001
# Optional: lax | strict | none — auto-detected from FRONT_END_URL vs PUBLIC_BASE_URL in production
# COOKIE_SAME_SITE=none
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=Shortly <noreply@yourdomain.com>
# Public frontend URL for email images (required when FRONT_END_URL is localhost)
EMAIL_ASSET_BASE_URL=https://shortly.nayan04.me
# Optional: MongoDB IP family — 4 (IPv4) or 6 (IPv6). Omit to use system default.
# MONGODB_IP_FAMILY=4
