{
  "name": "backend",
  "version": "1.0.0",
  "description": "Privacy-focused URL shortener API with authentication and analytics",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon index.js",
    "start": "node index.js",
    "lint": "eslint .",
    "test": "node --test --test-concurrency=1",
    "test:watch": "node --test --test-concurrency=1 --watch",
    "audit": "npm audit --audit-level=high",
    "ci": "npm run lint && npm run test"
  },
  "keywords": [
    "url-shortener",
    "express",
    "mongodb",
    "analytics"
  ],
  "author": "Nayan Swarnkar",
  "license": "MIT",
  "overrides": {
    "path-to-regexp": "^8.4.0",
    "picomatch": "^2.3.2"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "geoip-lite": "^1.4.10",
    "helmet": "^8.2.0",
    "joi": "^18.2.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.24.1",
    "nanoid": "^5.1.16",
    "resend": "^6.17.2",
    "ua-parser-js": "^1.0.41"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "eslint": "^9.39.5",
    "globals": "^16.5.0",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
